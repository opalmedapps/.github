{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>opalmedapps/.github//base.renovate.json5',
  ],
  assignees: [],
  packageRules: [
    {
      matchManagers: [
        'pre-commit',
      ],
      matchPackageNames: [
        '!/markdownlint-cli2/',
        '!/reuse-tool/',
      ],
    },
    {
      matchPackageNames: [
        '/reuse-tool/',
        '/reuse-action/',
      ],
      groupName: 'reuse',
    },
  ],
  'renovate-config': {
    managerFilePatterns: [
      'renovate.json5',
      'base.renovate.json5',
    ],
  },
}
